model MarketplaceOrder {
  id            String              @id @default(cuid())
  empresaId     String
  plataforma    MarketplacePlatform
  numeroExterno String
  comprador     String
  produtoNome   String
  quantidade    Int
  valor         Float
  status        String              @default("pago") // pago, enviado, entregue, cancelado
  rastreio      String?
  slaEnvio      Int                 @default(48) // horas
