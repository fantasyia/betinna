// ─── INTEGRAÇÕES (tokens criptografados) ──────────────────────────────

model IntegracaoConexao {
  id                String    @id @default(cuid())
  empresaId         String
  servico           String // omie, ml, shopee, amazon, tiktok, whatsapp, instagram, fb
  ativo             Boolean   @default(false)
  credenciais       Json // criptografada na app
  /// ID externo da conta vinculada (não-cifrado, indexável). Ex: pageId pro Facebook,
  /// IGSID pro Instagram. Usado pra routing reverso do webhook → empresa.
  externalAccountId String?
  ultimoSync        DateTime?
  errosRecentes     Int       @default(0)
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt

  @@unique([empresaId, servico])
  @@index([empresaId])
  @@index([servico, externalAccountId])
}

// Semáforo de saúde de cada integração por empresa (Sprint 2.1).
// Alimentado pelos hooks de sucesso/erro das integrações. A UI mostra o badge
// (verde/amarelo/vermelho) e o backend dispara alerta por e-mail quando cai.
enum IntegracaoStatusValor {
  ATIVA // funcionando
  DEGRADADA // algumas falhas recentes, ainda responde
  CAIDA // falhou várias vezes seguidas
  DESCONECTADA // token expirou / sessão caiu / credencial inválida
}

model IntegracaoStatus {
  id                  String                @id @default(cuid())
  empresaId           String
  servico             String // omie, whatsapp, mercadolivre, shopee, amazon, tiktok, instagram, facebook
  status              IntegracaoStatusValor @default(ATIVA)
  ultimoErro          String? // mensagem do último erro (pra tooltip/diagnóstico)
  ultimoErroEm        DateTime?
  ultimaVerificacaoEm DateTime              @default(now())
  errosSeguidos       Int                   @default(0) // contador pra detectar "caiu"
  ultimoAlertaEm      DateTime? // throttle do e-mail (1 por integração por hora)
  criadoEm            DateTime              @default(now())
  atualizadoEm        DateTime              @updatedAt

  @@unique([empresaId, servico])
  @@index([empresaId])
}

// Integrações com escopo USUÁRIO (não empresa). Cada rep tem sua própria conexão.
// Usado por: sendgrid (e-mail pessoal do rep), google_calendar (agenda do rep),
// openai/anthropic (chave pessoal pra MullerBot, se opt-in).
model UsuarioIntegracao {
  id            String    @id @default(cuid())
  usuarioId     String
  servico       String // sendgrid, google_calendar, openai, anthropic
  ativo         Boolean   @default(false)
  credenciais   Json // criptografada na app
  ultimoSync    DateTime?
  errosRecentes Int       @default(0)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, servico])
  @@index([usuarioId])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  usuarioId String?
  empresaId String?
  acao      String // create, update, delete, login, etc
  recurso   String // cliente, pedido, etc
  recursoId String?
  detalhes  Json?
  ip        String?
  criadoEm  DateTime @default(now())

  @@index([usuarioId])
  @@index([empresaId])
  @@index([criadoEm])
}

// ─── PROGRAMA DE FIDELIDADE ────────────────────────────────────────────
// MVP B2B: cliente acumula pontos a cada pedido, resgata por recompensas
// (desconto% / desconto valor / brinde).
//
// Decisões:
// - 1 programa por empresa (singleton via @unique). DIRECTOR/ADMIN configura.
// - TTL de pontos em meses (default 12) — expiração rodada por cron.
// - Trigger automático: pedido ENVIADO_OMIE/ENTREGUE → gera MovimentoFidelidade
//   GANHO_PEDIDO. Re-cancelamento gera MovimentoFidelidade ESTORNO_PEDIDO.
// - Idempotência: @@unique([pedidoId, tipo]) impede dupla creditação.
// - Saldo é DESNORMALIZADO em SaldoFidelidade.pontos. Cada movimento atualiza
//   o saldo atomicamente dentro de transaction. Cron mensal recalcula como
//   safety net contra drift.
enum MovimentoFidelidadeTipo {
  GANHO_PEDIDO // pedido aprovado → ganha pontos
  ESTORNO_PEDIDO // pedido cancelado → estorna pontos do GANHO_PEDIDO
  RESGATE // cliente resgata recompensa
  EXPIRACAO // pontos expiraram (cron mensal)
  AJUSTE_MANUAL // DIRECTOR/ADMIN ajusta manualmente (motivo obrigatório)
}

enum RecompensaTipo {
  DESCONTO_PERCENTUAL // valor em % (0–100)
  DESCONTO_VALOR // valor em R$
  BRINDE // valor opcional (descrição texto)
}

/// Segmento — grupos de clientes definidos por regras visuais (filtros encadeáveis).
/// Avaliado on-demand quando o user lista o segmento (não materializado).
model Segmento {
  id           String   @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?  @db.Text
  /// Estrutura JSON com condições + lógica (AND/OR).
  /// Ex: { logic: 'AND', conditions: [{ campo: 'status', op: 'eq', valor: 'ATIVO' }, ...] }
  regrasJson   Json
  cor          String?  @default("#facc15")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nome])
  @@index([empresaId, ativo])
}

/// Metas — definição + acompanhamento por rep/gerente/equipe.
/// Calcula atingimento agregando pedidos no período.
model Meta {
  id            String   @id @default(cuid())
  empresaId     String
  titulo        String
  descricao     String?  @db.Text
  /// Tipo: FATURAMENTO (somatório de pedido.total) ou PEDIDOS (contagem)
  tipo          String   @default("FATURAMENTO")
  /// Valor alvo (R$ pra FATURAMENTO, contagem pra PEDIDOS)
  valorAlvo     Decimal  @db.Decimal(14, 2)
  /// A quem se aplica: REP (representanteId), EMPRESA (toda), GERENTE (gerenteId)
  alvoTipo      String   @default("REP")
  /// ID do REP ou GERENTE (null se alvoTipo=EMPRESA)
  alvoId        String?
  /// Período: MES, TRIMESTRE, ANO
  periodicidade String   @default("MES")
  /// Início do período (1º dia do mês/trimestre/ano)
  inicio        DateTime
  /// Fim do período (último dia)
  fim           DateTime
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, ativo])
  @@index([empresaId, alvoTipo, alvoId])
}

/// NPS — pesquisas de Net Promoter Score.
/// Pesquisa tem prazo de envio (criadoEm → expiraEm), slug público pra responder.
model PesquisaNPS {
  id                    String    @id @default(cuid())
  empresaId             String
  slug                  String    @unique
  titulo                String
  descricao             String?   @db.Text
  /// Mensagem exibida após responder
  mensagemAgradecimento String?   @db.Text
  /// Pergunta principal (default: "O quanto você nos recomendaria?")
  pergunta              String    @default("O quanto você nos recomendaria de 0 a 10?")
  /// Pergunta de follow-up (default: "Por quê?")
  perguntaFollowUp      String?   @default("Conta pra gente o que motivou essa nota")
  ativo                 Boolean   @default(true)
  /// Quando expira (link vira inválido)
  expiraEm              DateTime?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  empresa   Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  respostas RespostaNPS[]

  @@index([empresaId, ativo])
}

model RespostaNPS {
  id         String   @id @default(cuid())
  pesquisaId String
  /// Nota de 0 a 10
  nota       Int
  /// Resposta textual do follow-up
  comentario String?  @db.Text
  /// E-mail/telefone do respondente (pra contactar se promotor/detrator)
  contato    String?
  /// Cliente identificado (se a pesquisa veio por link tracking)
  clienteId  String?
  /// Categoria derivada: DETRATOR (0-6), PASSIVO (7-8), PROMOTOR (9-10)
  categoria  String
  ip         String?
  userAgent  String?
  /// Marca registros gerados pelo seed-demo.
  isDemo     Boolean  @default(false)
  criadoEm   DateTime @default(now())

  pesquisa PesquisaNPS @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  cliente  Cliente?    @relation("ClienteRespostaNPS", fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([pesquisaId, criadoEm])
  @@index([pesquisaId, categoria])
  @@index([clienteId])
  // Seed demo
  @@index([isDemo])
}

/// Form Builder — formulários públicos pra capturar leads.
/// Acessível via /f/:slug (sem auth). Submit cria um Lead + FormularioResposta.
model Formulario {
  id                  String   @id @default(cuid())
  empresaId           String
  /// Slug único pra URL pública (/f/:slug). Lowercase, sem acento.
  slug                String   @unique
  titulo              String
  descricao           String?  @db.Text
  /// Mensagem de sucesso pós-envio
  mensagemSucesso     String?  @db.Text
  /// Onde redirecionar após o submit (opcional)
  redirectUrl         String?
  /// Quando true, novos envios criam Lead automaticamente
  geraLead            Boolean  @default(true)
  /// Etapa inicial do Lead quando criado por este form
  leadEtapaInicial    String?  @default("NOVO")
  /// Quem é notificado em cada submissão (lista de userIds)
  notificarUsuarioIds Json?
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  empresa   Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  campos    FormularioCampo[]
  respostas FormularioResposta[]

  @@index([empresaId, ativo])
}

/// Campo de um Formulario. Order define a sequência na renderização.
model FormularioCampo {
  id           String  @id @default(cuid())
  formularioId String
  ordem        Int
  /// Tipo do campo: TEXT, EMAIL, TEL, NUMERO, TEXTAREA, SELECT, CHECKBOX, RADIO
  tipo         String
  label        String
  /// Nome interno (chave no JSON de respostas). Slug do label se vazio.
  campo        String
  placeholder  String?
  obrigatorio  Boolean @default(false)
  /// Opções pra SELECT/RADIO/CHECKBOX (array de strings em JSON)
  opcoes       Json?
  /// Validação extra: { minLength?, maxLength?, pattern? }
  validacao    Json?
  /// Hint exibido abaixo do campo
  hint         String?
  /// v1.5.0 — Passo multi-step (1..N). Default 1 = formulário single-step.
  passo        Int     @default(1)

  formulario Formulario @relation(fields: [formularioId], references: [id], onDelete: Cascade)

  @@index([formularioId, ordem])
  @@index([formularioId, passo])
}

model FormularioResposta {
  id           String   @id @default(cuid())
  formularioId String
  /// Dados submetidos (chave = campo.campo, valor = string)
  dados        Json
  /// IP do submitter (rate limit + abuse detection)
  ip           String?
  /// User-Agent capturado
  userAgent    String?
  /// Lead criado a partir dessa resposta (null se gerou Lead falhou ou geraLead=false)
  leadId       String?
  criadoEm     DateTime @default(now())

  formulario Formulario @relation(fields: [formularioId], references: [id], onDelete: Cascade)

  @@index([formularioId, criadoEm])
  @@index([leadId])
}

/// Persona do MullerBot — tom/voz/exemplos customizados por empresa.
/// O system prompt é compilado a partir desses campos pra dar identidade.
/// Singleton por empresa (1 persona ativa por tenant).
model MullerBotPersona {
  id           String  @id @default(cuid())
  empresaId    String  @unique
  nome         String  @default("MullerBot")
  /// Tom de voz: FORMAL, PROFISSIONAL, AMIGAVEL, DESCONTRAIDO, ENTUSIASMADO
  tomVoz       String  @default("PROFISSIONAL")
  /// Instruções extras anexadas ao system prompt base.
  /// Ex: "Sempre cite o prazo de entrega. Use emojis com moderação."
  instrucoes   String? @db.Text
  /// Prompt COMPLETO escrito pelo usuário. Quando preenchido, é usado tal e qual
  /// como system prompt (substitui o prompt-base e os campos estruturados acima).
  /// É a forma principal de configurar o Muller — os demais campos viram legado.
  promptCustom String? @db.Text
  /// Modelo da OpenAI usado pelo bot desta empresa (ex: gpt-4o-mini, gpt-4o).
  /// Quando null, usa o padrão do servidor (env MULLERBOT_MODEL).
  modelo       String?
  /// Exemplos de pergunta/resposta pro few-shot prompt (array JSON).
  /// Ex: [{pergunta: "Tem óleo de soja?", resposta: "Sim, em três tamanhos..."}]
  exemplosJson Json?
  /// Saudação opcional usada em mensagens iniciais (Inbox/templates).
  saudacao     String?
  ativo        Boolean @default(true)

  /// Sprint 2.2 — Teto de custo (tokens OpenAI) por empresa.
  limiteTokensDiaIn   Int       @default(100000)
  limiteTokensDiaOut  Int       @default(100000)
  limiteTokensMesIn   Int       @default(2000000)
  limiteTokensMesOut  Int       @default(2000000)
  /// Quando o bot se auto-pausou por estourar o teto (vale até essa data — virada do dia/mês).
  pausadoPorCustoAte  DateTime?
  /// Throttle do alerta de 80% do teto (no máx. 1 e-mail por dia).
  ultimoAlertaCustoEm DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

/// Orquestração Fase A — biblioteca de prompts por empresa (multi-prompt).
/// Vários prompts reutilizáveis; o marcado `isPadrao` é o "prompt global" (retrocompat
/// da persona única). O nó "Conversar com IA" (Fase B) referenciará um prompt por id.
model BotPrompt {
  id          String  @id @default(cuid())
  empresaId   String
  nome        String
  descricao   String? @db.Text
  /// System prompt completo — usado tal e qual pelo bot.
  texto       String  @db.Text
  /// Override do modelo OpenAI (null = usa o da empresa/persona).
  modelo      String?
  temperatura Float?  @default(0.7)
  /// Prompt padrão da empresa (no máximo 1 — garantido em código).
  isPadrao    Boolean @default(false)
  ativo       Boolean @default(true)
  /// Versionamento pra rollback/A-B (spec §7).
  versao      Int     @default(1)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@index([empresaId, isPadrao])
}

/// Sprint 2.2 — status de cada resposta do bot (pra auditoria).
enum BotRespostaStatus {
  OK
  FALLBACK
  SEM_RESPOSTA
}

/// Sprint 2.2 — registro de cada resposta do bot (auditoria + flag de revisão).
model BotResposta {
  id             String            @id @default(cuid())
  empresaId      String
  conversationId String?
  messageId      String?
  pergunta       String            @db.Text
  resposta       String?           @db.Text
  tokensIn       Int               @default(0)
  tokensOut      Int               @default(0)
  tempoMs        Int?
  modelo         String?
  status         BotRespostaStatus @default(OK)
  /// Marcada automaticamente quando a resposta cita preço/estoque/prazo/etc.
  marcadaRevisao Boolean           @default(false)
  motivoRevisao  String?
  criadoEm       DateTime          @default(now())

  @@index([empresaId, criadoEm])
  @@index([empresaId, marcadaRevisao])
  @@index([conversationId])
}

/// Sprint 2.2 — contador diário de tokens consumidos pelo bot (teto de custo).
model BotUsoTokens {
  id           String   @id @default(cuid())
  empresaId    String
  dia          String // YYYY-MM-DD no fuso de Brasília
  tokensIn     Int      @default(0)
  tokensOut    Int      @default(0)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([empresaId, dia])
  @@index([empresaId])
}

/// Sprint 2.3 — Respostas rápidas / templates pra a Inbox.
model RespostaRapida {
  id           String   @id @default(cuid())
  empresaId    String
  criadoPorId  String
  titulo       String
  atalho       String // ex: "/obrigado" (sem unicidade — global e privados podem coexistir)
  conteudo     String   @db.Text
  categoria    String?
  /// true = visível pra empresa toda; false = privado do criador.
  global       Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([empresaId])
  @@index([criadoPorId])
}

model ProgramaFidelidade {
  id                String   @id @default(cuid())
  empresaId         String   @unique // singleton por empresa
  nome              String   @default("Programa de Fidelidade")
  ativo             Boolean  @default(true)
  // Quantos pontos ganha por R$ 1 gasto. Default 1.
  // Decimal pra permitir 0.5 (1 ponto a cada R$ 2) ou 2 (multiplicador).
  pontosPorReal     Decimal  @default(1) @db.Decimal(10, 4)
  // TTL de pontos em meses. 0 = nunca expira.
  ttlMeses          Int      @default(12)
  // Pedidos abaixo desse valor não geram pontos.
  valorMinimoPedido Decimal  @default(0) @db.Decimal(10, 2)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model RecompensaFidelidade {
  id           String         @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?
  custoPontos  Int
  tipo         RecompensaTipo
  valor        Decimal?       @db.Decimal(10, 2)
  // null = estoque ilimitado. Decrementa em cada resgate.
  estoque      Int?
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  empresa    Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  movimentos MovimentoFidelidade[]

  @@index([empresaId, ativo])
}

model SaldoFidelidade {
  id           String   @id @default(cuid())
  empresaId    String
  clienteId    String   @unique // 1 saldo por cliente (1:1)
  pontos       Int      @default(0)
  atualizadoEm DateTime @updatedAt
  criadoEm     DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}

model MovimentoFidelidade {
  id           String                  @id @default(cuid())
  empresaId    String
  clienteId    String
  tipo         MovimentoFidelidadeTipo
  // Positivo = ganho/ajuste+; Negativo = resgate/expiração/ajuste-.
  pontos       Int
  // Origens (preenchidas conforme o tipo):
  pedidoId     String?
  recompensaId String?
  motivo       String? // obrigatório só pra AJUSTE_MANUAL
  criadoPorId  String?
  criadoEm     DateTime                @default(now())

  empresa    Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente    Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedido     Pedido?               @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  recompensa RecompensaFidelidade? @relation(fields: [recompensaId], references: [id], onDelete: SetNull)

  // Idempotência: 1 movimento por (pedido, tipo). Permite re-execução
  // segura do trigger. Para tipos sem pedidoId (RESGATE/EXPIRACAO/AJUSTE),
  // pedidoId é null e o constraint não aplica (Postgres permite múltiplos NULLs).
  @@unique([pedidoId, tipo])
  @@index([empresaId, clienteId, criadoEm])
  @@index([empresaId, tipo])
}

// ─── SEQUÊNCIAS ATÔMICAS POR EMPRESA ──────────────────────────────────
// Substitui o padrão race-condition `count() + 1` no `gerarNumero*`.
// Cada (empresaId, tipo) tem um contador atômico — incrementado via Redis
// INCR e persistido aqui para sobreviver a reinício do Redis.
// Tipos atuais: 'pedido', 'proposta', 'ocorrencia'.
model EmpresaSequence {
  id           String   @id @default(cuid())
  empresaId    String
  tipo         String // 'pedido' | 'proposta' | 'ocorrencia' | 'nf' | ...
  ultimo       Int      @default(0)
  atualizadoEm DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, tipo])
  @@index([empresaId])
}

// ─── NOTIFICAÇÕES IN-APP ──────────────────────────────────────────────
// Notificações persistidas por usuário. Criadas por triggers (aprovação
// pendente, ocorrência crítica, comissão fechada, pedido aprovado, etc).
// Marca como lida sem deletar — extrato fica.

enum NotificacaoTipo {
  APROVACAO_PENDENTE // gerente: aprovação aguardando
  APROVACAO_RESOLVIDA // rep: sua aprovação foi aprovada/rejeitada
  OCORRENCIA_ABERTA // sac/gerente: nova ocorrência crítica
  OCORRENCIA_RESOLVIDA // criador: sua ocorrência foi resolvida
  PEDIDO_APROVADO // rep: pedido foi pra OMIE
  COMISSAO_FECHADA // rep/gerente: mês fechou, valor disponível
  COMISSAO_PAGA // rep/gerente: marcado como pago
  MENSAGEM_INBOX // qualquer: nova mensagem inbox
  AMOSTRA_FOLLOWUP // rep: amostra precisa follow-up
  LEAD_INATIVO // rep: lead 7 dias na mesma etapa
  CLIENTE_BLOQUEADO // rep: cliente da carteira ficou BLOQUEADO no OMIE
  ESTOQUE_ZERADO // rep: produto que ele vendeu nos últimos 30d zerou o estoque
  GENERICO // notificação manual/admin
}

enum NotificacaoPrioridade {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

model Notificacao {
  id         String                @id @default(cuid())
  empresaId  String
  usuarioId  String // destinatário
  tipo       NotificacaoTipo
  prioridade NotificacaoPrioridade @default(NORMAL)
  titulo     String // ex: "Aprovação pendente"
  mensagem   String // ex: "Pedido PED-0042 com 25% desconto..."
  link       String? // rota frontend para deep-link, ex: "/aprovacoes/123"
  metadata   Json? // contexto extra (pedidoId, ocorrenciaId, etc)
  lidaEm     DateTime?
  criadoEm   DateTime              @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, lidaEm, criadoEm])
  @@index([empresaId, criadoEm])
}
