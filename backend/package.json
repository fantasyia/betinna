{
  "name": "betinna-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Betinna.ai — Backend API (NestJS + Prisma + Supabase)",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "worker": "node dist/worker",
    "worker:dev": "tsx watch src/worker.ts",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
    "db:generate": "prisma generate",
    "db:push": "node scripts/guard-db-push.js",
    "db:push:force": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev && node scripts/update-schema-hash.js",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:check-drift": "node scripts/check-migration-drift.js",
    "db:update-hash": "node scripts/update-schema-hash.js",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "seed:admin": "tsx prisma/seed.ts",
    "load:smoke": "k6 run ../load-tests/smoke.js",
    "load:stress": "k6 run ../load-tests/stress.js",
    "load:spike": "k6 run ../load-tests/spike.js",
    "prepare": "prisma generate"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.13",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.13",
    "@nestjs/platform-express": "^11.0.13",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.46.0",
    "@whiskeysockets/baileys": "^7.0.0-rc11",
    "bullmq": "^5.34.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "nestjs-pino": "^4.4.0",
    "nestjs-zod": "^4.3.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.0.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^3.0.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.4"
  }
}
