# =====================================================================
# BETINNA.AI — variáveis de ambiente do backend
# Copie para .env.local e preencha. NUNCA commite .env.local.
# =====================================================================

# ─── APP ──────────────────────────────────────────────────────────────
NODE_ENV="development"             # development | test | production
PORT="3001"
API_PREFIX="api/v1"
LOG_LEVEL="debug"                  # fatal | error | warn | info | debug | trace
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── DATABASE (Supabase Postgres) ─────────────────────────────────────
# Settings → Database → Connection string
# DATABASE_URL: Transaction pooler (porta 6543), com ?pgbouncer=true
# DIRECT_URL: Session pooler (porta 5432), pra migrations
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── SUPABASE AUTH + STORAGE ──────────────────────────────────────────
# Settings → API
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
SUPABASE_JWT_SECRET=""              # Settings → API → JWT Settings → JWT Secret

# ─── REDIS (BullMQ + cache) ───────────────────────────────────────────
# Local: redis://localhost:6379  |  Upstash: rediss://...
REDIS_URL="redis://localhost:6379"

# ─── CRYPTO (criptografia AES-256 de tokens de integração) ───────────
# Gerar com: openssl rand -hex 32  (ou Node: crypto.randomBytes(32).toString('hex'))
ENCRYPTION_KEY=""                   # 64 caracteres hex

# ─── IA (MullerBot) ───────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── OMIE (ERP) ───────────────────────────────────────────────────────
OMIE_APP_KEY=""
OMIE_APP_SECRET=""
OMIE_WEBHOOK_SECRET=""                  # OBRIGATÓRIO em produção (HMAC webhook)
# OMIE_DEMO_MODE=true → cliente devolve dados mock (sem chamar API real)
# Útil em dev/test. Coloque false em prod com OMIE_APP_KEY válida.
OMIE_DEMO_MODE="true"
OMIE_BASE_URL="https://app.omie.com.br/api/v1"
OMIE_TIMEOUT_MS="30000"

# ─── WhatsApp Business Cloud (Meta) ───────────────────────────────────
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# ─── Mercado Livre ────────────────────────────────────────────────────
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI=""
# ML não tem HMAC oficial. Em produção, OBRIGATÓRIO whitelist de IPs do ML.
# Lista comma-separated. Default cobre IPs documentados pelo ML em 2024.
ML_WEBHOOK_IP_WHITELIST="54.88.218.97,18.215.140.160,18.213.114.129,18.206.34.84"

# ─── Shopee ───────────────────────────────────────────────────────────
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""                  # OBRIGATÓRIO em produção (HMAC webhook)
SHOPEE_REDIRECT_URI=""

# ─── Amazon SP-API ────────────────────────────────────────────────────
AMAZON_CLIENT_ID=""
AMAZON_CLIENT_SECRET=""
AMAZON_REFRESH_TOKEN=""
AMAZON_REGION="us-east-1"

# ─── TikTok Shop ──────────────────────────────────────────────────────
TIKTOK_APP_KEY=""
TIKTOK_APP_SECRET=""                   # OBRIGATÓRIO em produção (HMAC webhook)

# ─── Instagram / Facebook ─────────────────────────────────────────────
META_GRAPH_APP_ID=""
META_GRAPH_APP_SECRET=""               # OBRIGATÓRIO em produção (HMAC webhook)
META_GRAPH_VERIFY_TOKEN=""             # OBRIGATÓRIO em produção (handshake GET)

# ─── Google (Calendar OAuth pro rep) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# ─── E-mail transacional ──────────────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@betinna.ai"
SENDGRID_FROM_NAME="Betinna.ai"

# ─── Google Ads API (Admin Ads Intelligence) ──────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_REDIRECT_URI=""

# ─── Meta Ads API (Admin Ads Intelligence) ────────────────────────────
META_ADS_APP_ID=""
META_ADS_APP_SECRET=""
META_ADS_REDIRECT_URI=""

# ─── Ads Intelligence — controle de write actions ─────────────────────
# Quando false (padrão), o módulo só faz leitura/BI.
# True habilita controles de campanha (pausar, ativar, alterar orçamento)
# com fluxo de aprovação obrigatório.
ADS_WRITE_CONTROLS_ENABLED="false"

# ─── Observabilidade ──────────────────────────────────────────────────
# DSN do Sentry. Quando vazio, observabilidade externa é DESLIGADA (no-op).
# Em produção, criar projeto Sentry e colar o DSN aqui.
# Sprint 3 FIX 5 — beforeSend já aplica sanitização PII (sanitize-pii.ts).
SENTRY_DSN=""

# ─── Auth Cache (AuthGuard via Redis) ─────────────────────────────────
# TTL do cache de usuário autenticado em segundos. Mantenha curto (30-60s)
# pra que mudanças de role/status reflitam rapidamente.
AUTH_CACHE_TTL_SECONDS="60"

# ─── Deploy identity (para cron locks) ────────────────────────────────
# Identificador único da réplica. Em Railway, usar ${RAILWAY_REPLICA_ID}
# ou hostname do container. Fallback para `host-<pid>` se vazio.
INSTANCE_ID=""
